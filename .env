# Application Configuration
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Paths
RAW_VIDEO_DIR=data/raw_videos
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models
EXPERIMENTS_DIR=experiments

# Model Configuration
MODEL_TYPE=multimodal
USE_GPU=True
GPU_DEVICE=0
BATCH_SIZE=8

# Training Configuration
LEARNING_RATE=0.0001
NUM_EPOCHS=50
EARLY_STOPPING_PATIENCE=10

# Audio Processing
WHISPER_MODEL=base
AUDIO_SAMPLE_RATE=16000
LANGUAGE=en

# Video Processing
FRAME_RATE=30
FRAME_WIDTH=1280
FRAME_HEIGHT=720
CLIP_DURATION=5

# Event Detection
CONFIDENCE_THRESHOLD=0.7
BUFFER_BEFORE=5
BUFFER_AFTER=10

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=football-highlights
WANDB_ENTITY=your_entity

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Database
DATABASE_URL=postgresql://user:Arbin@localhost/football_highlights
REDIS_URL=redis://localhost:6379/0